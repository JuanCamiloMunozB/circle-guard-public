# Template for the project-root .env file (circle-guard-public/.env).
# Copy to the project root and fill in real values. Never commit the real .env.
#
# docker-compose.jenkins.yml loads this via `env_file: - ../../.env`
# (two levels up from jenkins/config/ = project root).

# --- Jenkins admin ---
JENKINS_ADMIN_USERNAME=admin
JENKINS_ADMIN_PASSWORD=changeme

# --- Jenkins URL ---
# Local docker-compose: http://host.docker.internal:8080/
# Jenkins-in-AKS:       http://jenkins.default.svc.cluster.local:8080/  (default, set in casc.yaml)
JENKINS_URL=http://host.docker.internal:8080/

# --- Git repository ---
GIT_REPO_URL=https://github.com/JuanCamiloMunozB/circle-guard-public.git
GIT_BRANCH=develop

# --- Docker Hub ---
DOCKERHUB_USERNAME=juancamuba
DOCKERHUB_TOKEN=<docker-hub-access-token>
# Base64-encoded content of ~/.docker/config.json after `docker login`.
# Generate (Git Bash / WSL):  cat ~/.docker/config.json | base64 -w0
# Generate (PowerShell):      [Convert]::ToBase64String([System.IO.File]::ReadAllBytes("$env:USERPROFILE\.docker\config.json"))
DOCKERHUB_CONFIG_B64=<base64-of-docker-config.json>

# --- SonarCloud ---
SONAR_HOST_URL=https://sonarcloud.io
SONAR_TOKEN=<sonarcloud-user-token>

# --- Slack (Incoming Webhook) ---
# Create an Incoming Webhook: api.slack.com/apps → your app → Incoming Webhooks →
# Add New Webhook to Workspace → pick the #ci-alerts channel. Slack returns a full
# URL of the form  https://hooks.slack.com/services/<TEAM>/<BOT>/<SECRET>
# Set SLACK_WEBHOOK_TOKEN to ONLY the part AFTER /services/ , i.e. <TEAM>/<BOT>/<SECRET>.
# The Jenkins Slack plugin prepends the https://hooks.slack.com/services/ base URL.
SLACK_WEBHOOK_TOKEN=<TEAM>/<BOT>/<SECRET>

# --- GitHub PAT (repo:write) for bump-and-tag.sh --push ---
GITHUB_PAT=<github-personal-access-token>

# --- Gmail SMTP (email notifications on pipeline failure) ---
# Gmail rejects your normal password for SMTP. Create a Google App Password:
#   Google Account → Security → 2-Step Verification (must be ON) → App passwords.
# Use the 16-char app password (no spaces) as SMTP_PASSWORD.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=juancamuba.swe@gmail.com
SMTP_USERNAME=juancamuba.swe@gmail.com
SMTP_PASSWORD=<gmail-app-password>

# --- Kubernetes (leave empty when Jenkins runs IN AKS — uses in-cluster SA) ---
# Set these only when running Jenkins via local docker-compose pointing at AKS:
#   K8S_API_SERVER:        az aks show -n aks-cg-dev -g rg-cg-dev --query fqdn -o tsv → https://<fqdn>
#   K8S_SA_TOKEN:          kubectl get secret jenkins-token -n default -o jsonpath='{.data.token}' | base64 -d
#   K8S_SA_CREDENTIALS_ID: k8s-sa-token  (the credential id defined in casc.yaml)
#   K8S_API_CA_CERT:       kubectl get secret jenkins-token -n default -o jsonpath='{.data.ca\.crt}'
K8S_API_SERVER=
K8S_SA_TOKEN=
K8S_SA_CREDENTIALS_ID=
K8S_API_CA_CERT=
