# CircleGuard environment variables.
#
# Copy to .env (gitignored) and fill in real values for local runs.
# Read by:
#   - jenkins/config/docker-compose.jenkins.yml (env_file: ../../.env)
#     Used to populate Jenkins via JCasC at startup.
#   - JCasC reads JENKINS_ADMIN_*, GIT_*, K8S_* from the container env.
#
# K8S_SA_TOKEN and K8S_API_SERVER are written automatically by:
#   bash jenkins/scripts/setup-k8s-jenkins.sh
# Run that script once before starting Jenkins.

# ----------------------------------------------------------------------------
# Jenkins admin user (created by JCasC on first boot)
# ----------------------------------------------------------------------------
JENKINS_ADMIN_USERNAME=admin
JENKINS_ADMIN_PASSWORD=admin

# ----------------------------------------------------------------------------
# Git repository (used by the seed jobs in casc.yaml)
# ----------------------------------------------------------------------------
GIT_REPO_URL=https://github.com/JuanCamiloMunozB/circle-guard-public.git
GIT_BRANCH=main

# ----------------------------------------------------------------------------
# Kubernetes access — populated automatically by setup-k8s-jenkins.sh.
# Do not fill in manually; the script extracts these from the live cluster.
# ----------------------------------------------------------------------------
K8S_SA_TOKEN=
K8S_API_SERVER=
