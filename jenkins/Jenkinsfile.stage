// CircleGuard stage pipeline.
//
// Runs in an ephemeral pod inside AKS (kubernetes plugin), scheduled from the
// Kubernetes cloud declared in jenkins/config/casc.yaml. The pod is destroyed when
// the build finishes (no persistent agents on the cluster - CLAUDE.md sec.5.5).
//
// The pod definition lives in jenkins/podtemplates/kaniko-build-agent.yaml and
// includes containers: gradle, kaniko, kubectl, python. Each `sh` step below is
// wrapped in `container('<name>')` so it executes inside the right tooling image.
pipeline {
    agent {
        kubernetes {
            cloud 'aks-cg'
            defaultContainer 'jnlp'
            yamlFile 'jenkins/podtemplates/kaniko-build-agent.yaml'
        }
    }

    options {
        timeout(time: 45, unit: 'MINUTES')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
    }

    parameters {
        booleanParam(name: 'SKIP_DOCKER_BUILD', defaultValue: false, description: 'Skip JAR compilation and Kaniko image build (reuse existing tags)')
    }

    environment {
        REGISTRY        = 'docker.io/circleguard'
        K8S_NAMESPACE   = 'circleguard-stage'
        TARGET_PLATFORM = 'linux/arm64'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                script {
                    env.DEPLOY_TAG = params.SKIP_DOCKER_BUILD ? 'stage-latest' : "stage-${BUILD_NUMBER}"
                }
            }
        }

        stage('Unit Tests') {
            steps {
                container('gradle') {
                    sh './gradlew :services:circleguard-auth-service:test \
                                  :services:circleguard-identity-service:test \
                                  :services:circleguard-form-service:test \
                                  :services:circleguard-promotion-service:test \
                                  :services:circleguard-notification-service:test \
                                  :services:circleguard-dashboard-service:test \
                                  :services:circleguard-gateway-service:test \
                                  :services:circleguard-file-service:test \
                        --continue'
                }
            }
            post {
                always {
                    junit '**/build/test-results/test/*.xml'
                }
            }
        }

        stage('Integration Tests') {
            steps {
                container('gradle') {
                    sh './gradlew :services:circleguard-form-service:integrationTest \
                                  :services:circleguard-promotion-service:integrationTest \
                                  :services:circleguard-notification-service:integrationTest \
                                  :services:circleguard-identity-service:integrationTest \
                                  :services:circleguard-dashboard-service:integrationTest \
                        --continue'
                }
            }
            post {
                always {
                    junit '**/build/test-results/integrationTest/*.xml'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                container('gradle') {
                    withSonarQubeEnv('sonarqube') {
                        sh './gradlew sonar -Dsonar.qualitygate.wait=true --info'
                    }
                }
            }
        }

        stage('Quality Gate') {
            // Run on the controller (no container() wrapper): waitForQualityGate polls
            // the Sonar server until it reports a result, abortPipeline:true converts a
            // failed gate into a pipeline FAILURE so the slackSend in post fires.
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Build JARs') {
            when { not { expression { params.SKIP_DOCKER_BUILD } } }
            steps {
                container('gradle') {
                    sh './gradlew :services:circleguard-auth-service:bootJar \
                                  :services:circleguard-identity-service:bootJar \
                                  :services:circleguard-form-service:bootJar \
                                  :services:circleguard-promotion-service:bootJar \
                                  :services:circleguard-notification-service:bootJar \
                                  :services:circleguard-dashboard-service:bootJar \
                                  :services:circleguard-gateway-service:bootJar \
                                  :services:circleguard-file-service:bootJar \
                        --parallel'
                }
            }
        }

        stage('Build & Push Images (Kaniko)') {
            when { not { expression { params.SKIP_DOCKER_BUILD } } }
            steps {
                container('kaniko') {
                    script {
                        def services = [
                            [name: 'auth-service',         dir: 'circleguard-auth-service'],
                            [name: 'identity-service',     dir: 'circleguard-identity-service'],
                            [name: 'form-service',         dir: 'circleguard-form-service'],
                            [name: 'promotion-service',    dir: 'circleguard-promotion-service'],
                            [name: 'notification-service', dir: 'circleguard-notification-service'],
                            [name: 'dashboard-service',    dir: 'circleguard-dashboard-service'],
                            [name: 'gateway-service',      dir: 'circleguard-gateway-service'],
                            [name: 'file-service',         dir: 'circleguard-file-service'],
                        ]
                        services.each { svc ->
                            // Kaniko reads /kaniko/.docker/config.json (mounted from the
                            // `dockerhub-config-json` Secret in the namespace) for the push.
                            sh """
                                /kaniko/executor \\
                                    --context=`pwd` \\
                                    --dockerfile=services/${svc.dir}/Dockerfile \\
                                    --destination=${REGISTRY}/${svc.name}:stage-${BUILD_NUMBER} \\
                                    --destination=${REGISTRY}/${svc.name}:stage-latest \\
                                    --customPlatform=${TARGET_PLATFORM} \\
                                    --single-snapshot \\
                                    --no-push-cache
                            """
                        }
                    }
                }
            }
        }

        stage('Trivy Image Scan') {
            when { not { expression { params.SKIP_DOCKER_BUILD } } }
            steps {
                container('trivy') {
                    script {
                        def services = ['auth-service','identity-service','form-service','promotion-service',
                                        'notification-service','dashboard-service','gateway-service','file-service']
                        sh 'mkdir -p tests/security/reports'
                        services.each { svc ->
                            // Trivy reads /kaniko/.docker (mounted in the pod template)
                            // via the DOCKER_CONFIG env so it can pull from Docker Hub.
                            // --exit-code 1 blocks the pipeline on CRITICAL/HIGH.
                            sh """
                                trivy image \\
                                    --severity CRITICAL,HIGH \\
                                    --ignore-unfixed \\
                                    --exit-code 1 \\
                                    --no-progress \\
                                    --format json \\
                                    --output tests/security/reports/trivy-${svc}.json \\
                                    --ignorefile .trivyignore \\
                                    ${REGISTRY}/${svc}:stage-${BUILD_NUMBER}
                            """
                        }
                    }
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'tests/security/reports/trivy-*.json', allowEmptyArchive: true
                }
            }
        }

        stage('Deploy to Stage') {
            steps {
                container('kubectl') {
                    // Pod's serviceAccountName=jenkins; the RBAC in
                    // jenkins/config/jenkins-account.yaml grants the verbs needed in this ns.
                    sh "kubectl apply -f k8s/namespaces.yaml"
                    sh "kubectl apply -f k8s/configmap.yaml -n ${K8S_NAMESPACE}"
                    sh "kubectl apply -f k8s/deployments/ -n ${K8S_NAMESPACE}"
                    sh "kubectl apply -f k8s/services/ -n ${K8S_NAMESPACE}"
                    script {
                        ['auth-service', 'identity-service', 'form-service',
                         'promotion-service', 'notification-service', 'dashboard-service',
                         'gateway-service', 'file-service'].each { svc ->
                            sh "kubectl set image deployment/${svc} ${svc}=${REGISTRY}/${svc}:${env.DEPLOY_TAG} -n ${K8S_NAMESPACE}"
                        }
                    }
                }
            }
        }

        stage('Wait for Rollout') {
            steps {
                container('kubectl') {
                    script {
                        ['auth-service', 'identity-service', 'form-service',
                         'promotion-service', 'notification-service', 'dashboard-service',
                         'gateway-service', 'file-service'].each { svc ->
                            sh "kubectl rollout status deployment/${svc} -n ${K8S_NAMESPACE} --timeout=300s"
                        }
                    }
                }
            }
        }

        stage('E2E Tests') {
            steps {
                container('kubectl') {
                    sh """
                        kubectl port-forward -n ${K8S_NAMESPACE} svc/auth-service         8180:8180 &
                        kubectl port-forward -n ${K8S_NAMESPACE} svc/identity-service     8083:8083 &
                        kubectl port-forward -n ${K8S_NAMESPACE} svc/form-service         8086:8086 &
                        kubectl port-forward -n ${K8S_NAMESPACE} svc/promotion-service    8088:8088 &
                        kubectl port-forward -n ${K8S_NAMESPACE} svc/notification-service 8082:8082 &
                        kubectl port-forward -n ${K8S_NAMESPACE} svc/dashboard-service    8084:8084 &
                        sleep 5
                        chmod +x jenkins/scripts/run-e2e.sh
                        BASE_URL=http://localhost \\
                        AUTH_PORT=8180 IDENTITY_PORT=8083 FORM_PORT=8086 \\
                        PROMOTION_PORT=8088 NOTIFICATION_PORT=8082 DASHBOARD_PORT=8084 \\
                        jenkins/scripts/run-e2e.sh
                    """
                }
            }
            post {
                always {
                    container('kubectl') {
                        sh 'pkill -f "kubectl port-forward" || true'
                    }
                    junit 'tests/e2e/build/test-results/test/*.xml'
                }
            }
        }

        stage('OWASP ZAP Baseline') {
            // Runs ZAP against the gateway service exposed by NodePort (Service
            // gateway-service:30087). Fails the build on FAIL-level findings; WARNs are
            // surfaced in the archived report but do not break the pipeline.
            steps {
                container('zap') {
                    sh """
                        mkdir -p tests/security/reports
                        export TARGET_URL=http://gateway-service.${K8S_NAMESPACE}.svc.cluster.local:8087
                        # zap-baseline.py expects writable /zap/wrk
                        cp -r tests/security/reports /zap/wrk/ || true
                        zap-baseline.py \\
                            -t \$TARGET_URL \\
                            -r zap-report.html \\
                            -J zap-report.json \\
                            -w zap-warnings.md \\
                            -m 1 \\
                            -I || ZAP_RC=\$?
                        cp /zap/wrk/zap-report.html      tests/security/reports/ || true
                        cp /zap/wrk/zap-report.json      tests/security/reports/ || true
                        cp /zap/wrk/zap-warnings.md      tests/security/reports/ || true
                        # -I tells ZAP to NOT fail on WARN; we re-fail on rc 1 explicitly.
                        if [ "\${ZAP_RC:-0}" = "1" ]; then
                            echo "ZAP detected FAIL-level findings; failing build."
                            exit 1
                        fi
                    """
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'tests/security/reports/zap-report.*', allowEmptyArchive: true
                    publishHTML(target: [
                        reportDir: 'tests/security/reports',
                        reportFiles: 'zap-report.html',
                        reportName: 'OWASP ZAP Baseline Report',
                        keepAll: true,
                        alwaysLinkToLastBuild: true,
                        allowMissing: true
                    ])
                }
            }
        }

        stage('Performance Baseline') {
            steps {
                container('python') {
                    sh """
                        pip install --quiet locust
                        kubectl port-forward -n ${K8S_NAMESPACE} svc/form-service      8086:8086 &
                        kubectl port-forward -n ${K8S_NAMESPACE} svc/dashboard-service 8084:8084 &
                        sleep 3
                        chmod +x jenkins/scripts/run-locust.sh
                        LOCUST_HOST=http://localhost:8086 DASHBOARD_HOST=http://localhost:8084 PROFILE=baseline \\
                        jenkins/scripts/run-locust.sh
                    """
                }
            }
            post {
                always {
                    container('python') {
                        sh 'pkill -f "kubectl port-forward" || true'
                    }
                    publishHTML(target: [
                        reportDir: 'tests/performance/reports',
                        reportFiles: 'locust-report-baseline.html',
                        reportName: 'Stage Performance Report'
                    ])
                }
            }
        }
    }

    post {
        always {
            // Pod is destroyed automatically by the kubernetes plugin when the build ends;
            // cleanWs() just clears the workspace volume inside the pod before tear-down.
            cleanWs()
        }
        success {
            slackSend(
                color: 'good',
                channel: '#ci-alerts',
                tokenCredentialId: 'slack-webhook',
                message: ":white_check_mark: *${env.JOB_NAME}* #${env.BUILD_NUMBER} succeeded on `${env.BRANCH_NAME ?: env.GIT_BRANCH ?: 'unknown'}` <${env.BUILD_URL}|view log>"
            )
        }
        failure {
            slackSend(
                color: 'danger',
                channel: '#ci-alerts',
                tokenCredentialId: 'slack-webhook',
                message: ":x: *${env.JOB_NAME}* #${env.BUILD_NUMBER} FAILED on `${env.BRANCH_NAME ?: env.GIT_BRANCH ?: 'unknown'}` <${env.BUILD_URL}console|console log>"
            )
            emailext(
                subject: "[CircleGuard] ${env.JOB_NAME} #${env.BUILD_NUMBER} FAILED",
                body: """The pipeline ${env.JOB_NAME} build #${env.BUILD_NUMBER} on branch ${env.BRANCH_NAME ?: env.GIT_BRANCH ?: 'unknown'} failed.

Console: ${env.BUILD_URL}console
Build: ${env.BUILD_URL}""",
                recipientProviders: [developers(), culprits()]
            )
        }
    }
}
