# Template for the Docker Hub registry Secret consumed by Kaniko inside the
# ephemeral build pods of `jenkins/podtemplates/kaniko-build-agent.yaml`.
#
# NEVER commit the real file. Procedure:
#   1. Copy this file:
#        cp k8s/jenkins/dockerhub-secret.yaml.example k8s/jenkins/dockerhub-secret.yaml
#   2. Replace the placeholder with the real .dockerconfigjson value:
#        echo -n '{"auths":{"https://index.docker.io/v1/":{"auth":"<base64(user:token)>"}}}' \
#          | base64 -w0
#   3. Apply to each namespace where stage/master pipelines build:
#        kubectl apply -f k8s/jenkins/dockerhub-secret.yaml -n circleguard-stage
#        kubectl apply -f k8s/jenkins/dockerhub-secret.yaml -n circleguard-master
#   4. The real .yaml is gitignored. Verify with `git status` before committing.
#
# Alternative imperative form (no file at all):
#   kubectl create secret docker-registry dockerhub-config-json \
#     --docker-server=https://index.docker.io/v1/ \
#     --docker-username=<USER> \
#     --docker-password=<TOKEN> \
#     -n circleguard-stage
---
apiVersion: v1
kind: Secret
metadata:
  name: dockerhub-config-json
type: kubernetes.io/dockerconfigjson
data:
  .dockerconfigjson: REPLACE_ME_WITH_BASE64_OF_DOCKERCONFIGJSON
